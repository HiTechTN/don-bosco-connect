# ── APPLICATION ──────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── BASE DE DONNÉES ──────────────────────────────────────
DB_NAME=donbosco
DB_USER=donbosco_user
DB_PASSWORD=changeme_db_password
DB_HOST=db
DB_PORT=5432

# ── REDIS ────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_HOST=redis
REDIS_PORT=6379

# ── MINIO ────────────────────────────────────────────────
MINIO_ROOT_USER=donbosco_admin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_COURSES=courses
MINIO_BUCKET_AVATARS=avatars
MINIO_SECURE=false

# ── OLLAMA ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MAX_CONCURRENT_SESSIONS=10
OLLAMA_MAX_TOKENS_PER_SESSION=2000

# ── IA PARAMÈTRES ────────────────────────────────────────
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.70
CHUNK_SIZE=512
CHUNK_OVERLAP=64
AI_DAILY_TOKEN_LIMIT_PER_STUDENT=10000

# ── MONITORING ───────────────────────────────────────────
GRAFANA_PASSWORD=changeme_grafana_password

# ── SÉCURITÉ ─────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
CORS_ORIGINS=http://localhost:5173,https://donbosco.local
ENCRYPTION_KEY=

# ── UPLOAD ───────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=200
ALLOWED_MIME_TYPES=application/pdf,video/mp4,video/webm,image/jpeg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
