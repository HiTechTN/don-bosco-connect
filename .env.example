# ============================================================
# Don Bosco Connect — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# JAMAIS commiter le .env rempli
# ============================================================

# --- Application ---
ENVIRONMENT=development
APP_VERSION=2.1.0
DEBUG=true

# --- Base de données ---
DB_NAME=donbosco
DB_USER=donbosco_user
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_HOST=db
DB_PORT=5432

# --- Sécurité JWT ---
# Générer avec : openssl rand -hex 32
SECRET_KEY=CHANGE_ME_RUN_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- MFA / TOTP ---
MFA_ISSUER=DonBoscoConnect

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO (stockage fichiers) ---
MINIO_ROOT_USER=donbosco_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_COURSES=courses
MINIO_BUCKET_AVATARS=avatars
MINIO_SECURE=false

# --- IA / Ollama ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MAX_CONCURRENT_SESSIONS=10
OLLAMA_MAX_TOKENS_PER_SESSION=2000

# --- IA / RAG ---
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.70
CHUNK_SIZE=512
CHUNK_OVERLAP=64
AI_DAILY_TOKEN_LIMIT_PER_STUDENT=10000

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Sentry (optionnel, laisser vide pour désactiver) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# --- Backup ---
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# --- Monitoring ---
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# --- Sécurité ---
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
CORS_ORIGINS=http://localhost:5173,https://donbosco.local
ENCRYPTION_KEY=

# --- Upload ---
MAX_UPLOAD_SIZE_MB=200
ALLOWED_MIME_TYPES=application/pdf,video/mp4,video/webm,image/jpeg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8080/api/v1
VITE_WS_URL=ws://localhost:8080/ws
VITE_APP_VERSION=2.1.0
